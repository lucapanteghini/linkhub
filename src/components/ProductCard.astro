---
import { ui } from '../i18n/ui';

interface Props {
  product: any;
}
const { product } = Astro.props;
const { name, accent, icon, category, tagline, links, status } = product;
const comingSoon = status === 'coming_soon';

const appleSvg =
  '<path d="M16.4 12.6c0-2 1.6-3 1.7-3-1-1.4-2.4-1.6-2.9-1.6-1.2-.1-2.4.7-3 .7-.6 0-1.6-.7-2.6-.7-1.3 0-2.6.8-3.3 2-1.4 2.4-.4 6 1 8 .7 1 1.4 2 2.4 2 1 0 1.3-.6 2.5-.6s1.5.6 2.5.6 1.7-1 2.3-2c.7-1.1 1-2.2 1-2.2-.1 0-2-1-2.1-2.9zM14.4 6c.5-.7.9-1.6.8-2.5-.8 0-1.7.5-2.3 1.2-.5.6-.9 1.5-.8 2.4.9.1 1.8-.4 2.3-1.1z"/>';
const playSvg =
  '<path d="M3.6 2.2 13 11.6l-2.6 2.6L3.6 2.2zM3.6 21.8 10.4 9.8l2.6 2.6L3.6 21.8zM14.7 8.9l3 1.7c1 .6 1 1.6 0 2.2l-3 1.7-3-3 3-2.6zM3 1.7c-.3.2-.5.5-.5 1v18.6c0 .5.2.8.5 1L11.5 12 3 1.7z"/>';
const webSvg =
  '<path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20zm6.9 6h-2.8a15.6 15.6 0 0 0-1.3-3.3A8 8 0 0 1 18.9 8zM12 4c.8 1.1 1.4 2.4 1.8 4h-3.6c.4-1.6 1-2.9 1.8-4zM4.3 14a8 8 0 0 1 0-4h3.2a17 17 0 0 0 0 4zm.8 2h2.8c.3 1.2.8 2.3 1.3 3.3A8 8 0 0 1 5.1 16zM7.9 8H5.1a8 8 0 0 1 4.1-3.3C8.7 5.7 8.2 6.8 7.9 8zm4.1 12c-.8-1.1-1.4-2.4-1.8-4h3.6c-.4 1.6-1 2.9-1.8 4zm2.2-6H9.8a14.7 14.7 0 0 1 0-4h4.4a14.7 14.7 0 0 1 0 4zm.7 5.3c.5-1 1-2.1 1.3-3.3h2.8a8 8 0 0 1-4.1 3.3zM16.5 14a17 17 0 0 0 0-4h3.2a8 8 0 0 1 0 4z"/>';
---

<article class="card" style={`--card-accent:${accent}`}>
  <img class="card__icon" src={`/${icon}`} alt={`${name} icon`} width="72" height="72" loading="lazy" />
  <div class="card__body">
    <span class="card__cat">
      <span data-lang="it">{category.it}</span>
      <span data-lang="en" hidden>{category.en}</span>
    </span>
    <h3 class="card__name">{name}</h3>
    <p class="card__tagline">
      <span data-lang="it">{tagline.it}</span>
      <span data-lang="en" hidden>{tagline.en}</span>
    </p>
    <div class="card__links">
      {
        comingSoon && (
          <span class="store-btn store-btn--soon">
            <span data-lang="it">{ui.it['badge.soon']}</span>
            <span data-lang="en" hidden>{ui.en['badge.soon']}</span>
          </span>
        )
      }
      {
        !comingSoon && links.appstore && (
          <a class="store-btn" href={links.appstore} target="_blank" rel="noopener noreferrer">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" set:html={appleSvg} />
            {ui.it['cta.appstore']}
          </a>
        )
      }
      {
        links.playstore && (
          <a class="store-btn" href={links.playstore} target="_blank" rel="noopener noreferrer">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" set:html={playSvg} />
            {ui.it['cta.playstore']}
          </a>
        )
      }
      {
        links.website && (
          <a class="store-btn" href={links.website} target="_blank" rel="noopener noreferrer">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" set:html={webSvg} />
            <span data-lang="it">{ui.it['cta.website']}</span>
            <span data-lang="en" hidden>{ui.en['cta.website']}</span>
          </a>
        )
      }
    </div>
  </div>
</article>
