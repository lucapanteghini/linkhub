---
import Base from '../layouts/Base.astro';
import SocialBar from '../components/SocialBar.astro';
import ProductCard from '../components/ProductCard.astro';
import { ui } from '../i18n/ui';
import productsData from '../../data/products.json';
import socialsData from '../../data/socials.json';

const products = productsData.products;
const { profile } = socialsData;
const year = 2026;
const contactEmail =
  socialsData.socials.find((s: any) => s.id === 'email')?.url || 'mailto:luca.panteghini@nurale.com';
---

<Base>
  <main class="wrap">
    <div class="topbar">
      <button id="lang-toggle" class="lang-toggle" type="button">
        <span data-lang="it">{ui.it['lang.toggle']}</span>
        <span data-lang="en" hidden>{ui.en['lang.toggle']}</span>
      </button>
    </div>

    <header class="profile">
      <img
        class="profile__avatar"
        src={`/${profile.avatar}`}
        alt={profile.name}
        width="92"
        height="92"
      />
      <h1 class="profile__name">{profile.name}</h1>
      <p class="profile__bio">
        <span data-lang="it">{profile.bio.it}</span>
        <span data-lang="en" hidden>{profile.bio.en}</span>
      </p>
    </header>

    <SocialBar />

    <section aria-labelledby="apps-heading">
      <h2 id="apps-heading" class="section-title">
        <span data-lang="it">{ui.it['apps.heading']}</span>
        <span data-lang="en" hidden>{ui.en['apps.heading']}</span>
      </h2>
      <div class="cards">
        {products.map((product: any) => <ProductCard product={product} />)}
      </div>
    </section>

    <footer class="footer">
      <p>
        <a href={contactEmail}>
          <span data-lang="it">{ui.it['footer.contact']}</span>
          <span data-lang="en" hidden>{ui.en['footer.contact']}</span>
        </a>
      </p>
      <p>© {year} {profile.name}. <span data-lang="it">{ui.it['footer.rights']}</span><span data-lang="en" hidden>{ui.en['footer.rights']}</span></p>
    </footer>
  </main>
</Base>
